{
  "name": "meaningful-ink-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w apps/website",
    "dev:website": "npm run dev -w apps/website",
    "dev:dashboard-web": "npm run dev -w apps/dashboard-web",
    "dev:dashboard-api": "npm run dev -w apps/dashboard-api",
    "dev:knock": "npm run dev -w apps/knock",
    "build": "npm run build -w apps/website",
    "build:website": "npm run build -w apps/website",
    "build:dashboard-web": "npm run build -w apps/dashboard-web",
    "build:dashboard-api": "npm run build -w apps/dashboard-api",
    "build:knock": "npm run build -w apps/knock",
    "start": "npm run start -w apps/website",
    "lint": "npm run lint -w apps/website",
    "lint:website": "npm run lint -w apps/website",
    "validate:website-content": "node scripts/validate-website-content.mjs",
    "audit:website-english-content": "node scripts/audit-website-english-content.mjs",
    "contact:ops": "node scripts/manage-website-contact-submissions.mjs",
    "verify:website-static": "node scripts/verify-website-static-entrypoints.mjs",
    "verify:website-browser": "node scripts/verify-website-browser.mjs",
    "test": "node --test tests/*.test.js",
    "test:workspace": "node --test tests/workspaces.test.js"
  },
  "engines": {
    "node": ">=22 <23",
    "npm": ">=9"
  },
  "dependencies": {
    "tailwindcss": "^4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
