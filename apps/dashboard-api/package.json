{
  "name": "dashboard-api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node --env-file=.env --watch ./dist/src/index.js",
    "build": "tsc -p tsconfig.json",
    "start": "node --env-file=.env ./dist/src/index.js",
    "test": "npm run build && node --test --test-isolation=none ./dist/test/*.js"
  },
  "dependencies": {
    "ali-oss": "^6.21.0",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@types/ali-oss": "^6.16.11",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "typescript": "^5.4.3"
  }
}

