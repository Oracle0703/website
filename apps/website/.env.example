# Server-only credential for the free weather query lab.
# Create a free key at https://www.weatherapi.com/ and never rename this to NEXT_PUBLIC_*.
WEATHERAPI_KEY=

# Public URL capture is disabled unless the server value is exactly "true".
# Keep false on small/public deployments until the documented Nginx limits are active.
AI_PAGE_ANALYSIS_ENABLE_PUBLIC_CAPTURE=false
